# Supabase (set these after creating your Supabase project)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# GitHub Models (free, for AI question generation + answer marking)
GITHUB_MODELS_API_KEY=your-github-pat-here

# Wipe endpoint secret (must match Vercel env var)
WIPE_SECRET=your-wipe-secret-here

# Site URL
NEXT_PUBLIC_SITE_URL=https://learn.oscartechnews.com
